{
  "id": "project-workflow",
  "name": "Project Workflow",
  "description": "Advanced project workflow automation with smart code analysis, git history tracking, and GitHub REST API integration",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable/disable the plugin"
      },
      "autoAnalyze": {
        "type": "boolean",
        "default": true,
        "description": "Automatically analyze context before code changes"
      },
      "gitIntegration": {
        "type": "boolean",
        "default": true,
        "description": "Enable git history analysis"
      },
      "githubIntegration": {
        "type": "boolean",
        "default": false,
        "description": "Enable GitHub integration (requires token)"
      },
      "github": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "GitHub Personal Access Token (classic with repo scope)"
          },
          "defaultRepo": {
            "type": "string",
            "description": "Default repository (owner/repo format)"
          }
        },
        "description": "GitHub API configuration"
      }
    },
    "additionalProperties": false
  }
}
